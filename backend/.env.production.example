NODE_ENV=production
PORT=5000

# Use MongoDB Atlas or another production MongoDB.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/dinora_gullari?retryWrites=true&w=majority
# Set this only for a single-server deployment where MongoDB is bound locally.
# ALLOW_LOCAL_MONGODB=true

# Generate a long random value and keep it outside git.
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=12h

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_ADMIN_IDS=6874906701,1779520880

# Exact frontend production origin. Use CLIENT_URLS only if you have multiple origins.
CLIENT_URL=https://your-frontend-domain.uz
# CLIENT_URLS=https://your-frontend-domain.uz,https://admin.your-domain.uz

# Use none when frontend and backend are on different HTTPS domains.
# Use lax when frontend and backend are same-site.
COOKIE_SAME_SITE=none

# Persistent paths on the server.
BACKUP_ENABLED=true
BACKUP_DIR=/var/backups/dinora-gullari
LOG_DIR=/var/log/dinora-gullari

# Backend error logs and Telegram alerts for 500-level errors.
TELEGRAM_ERROR_ALERTS_ENABLED=true
TELEGRAM_ERROR_ALERT_THROTTLE_MS=300000
