NODE_ENV=production
PORT=5000

# Use MongoDB Atlas or another production MongoDB. Do not use localhost in production.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/dinora_gullari?retryWrites=true&w=majority

# Generate a long random value and keep it outside git.
# Example generator: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=12h

# Telegram bot token from BotFather. Keep it outside git.
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
TELEGRAM_ADMIN_IDS=6874906701,1779520880

# Exact frontend production origin, without trailing slash.
CLIENT_URL=https://your-frontend-domain.uz
# Optional comma-separated origins when you have multiple production frontends.
CLIENT_URLS=https://your-frontend-domain.uz

# Use none when frontend and backend are on different domains over HTTPS.
# Use lax when both are same-site.
COOKIE_SAME_SITE=none

# JSON body limit is used for compressed profile/store images.
REQUEST_BODY_LIMIT=10mb

# Per-IP API rate limit.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180

# Daily automatic JSON backup runs at 03:00 Asia/Tashkent.
# Use a persistent mounted directory on the server.
BACKUP_ENABLED=true
BACKUP_DIR=/var/backups/dinora-gullari

# Backend error logs and Telegram alerts for 500-level errors.
LOG_DIR=/var/log/dinora-gullari
TELEGRAM_ERROR_ALERTS_ENABLED=true
TELEGRAM_ERROR_ALERT_THROTTLE_MS=300000

# Optional Google Sheets mirror sync.
# Share the target spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor.
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=replace_with_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account-name@project-id.iam.gserviceaccount.com
# Keep escaped newlines when storing in .env: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=replace_with_service_account_private_key
GOOGLE_SHEETS_ORDERS_SHEET=Orders
GOOGLE_SHEETS_SALES_SHEET=Sales
